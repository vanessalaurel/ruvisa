# Copy to .env.production before `npm run build`, or set in Cloudflare Pages → Settings → Environment variables.
# Must include the path prefix /api (this app calls `${VITE_API_URL}/chat`, etc.)
#
# Example: public API tunnel
#   VITE_API_URL=https://your-subdomain.trycloudflare.com/api
# Example: ngrok
#   VITE_API_URL=https://abc123.ngrok-free.app/api
#
VITE_API_URL=
